    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const config = $('Set Configuration').first().json;\nconst pf = $json;\nconst item = { ...pf };\n\nconst siteBaseUrl = (config.site_base_url || 'https://silverman.pro').replace(/\\/$/, '');\nconst relativePath = (pf.relative_path || '').trim();\n\nif (!relativePath) {\n  return { json: { ...item, source_public_url: '', source_public_url_error: 'missing_relative_path' } };\n}\n\nconst basename = relativePath.split('/').pop() || '';\nlet slug = basename.replace(/\\.md$/i, '');\nconst slugMatch = slug.match(/^(\\d+)-(.+)$/);\nif (slugMatch) {\n  slug = slugMatch[2];\n}\n\nlet year;\nlet month;\nlet day;\nlet dateError = 'missing_frontmatter_date';\nconst content = pf.markdown_content || '';\nconst fmMatch = content.match(/^---\\s*\\n([\\s\\S]*?)\\n---/);\nif (fmMatch) {\n  const dateMatch = fmMatch[1].match(/^date:\\s*(.+)$/m);\n  if (dateMatch) {\n    const datePortion = dateMatch[1].trim().match(/^(\\d{4})-(\\d{2})-(\\d{2})/);\n    if (datePortion) {\n      year = datePortion[1];\n      month = datePortion[2];\n      day = datePortion[3];\n      dateError = null;\n    }\n  }\n}\n\nif (dateError) {\n  return { json: { ...item, source_public_url: '', source_public_url_error: dateError } };\n}\n\nconst slugPattern = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;\nif (!slugPattern.test(slug)) {\n  return { json: { ...item, source_public_url: '', source_public_url_error: 'invalid_public_slug' } };\n}\n\nconst sourcePublicUrl = `${siteBaseUrl}/${year}/${month}/${day}/${slug}/`;\nreturn { json: { ...item, source_public_url: sourcePublicUrl, source_public_url_error: '' } };"
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "name": "Compute Source Public URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2090,
        300
      ],
      "notes": "Derives source_public_url per item from site_base_url, frontmatter date, and filename slug."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Set Configuration').first().json.worker_base_url }}/generate-linkedin-draft",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
