        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (() => { const config = $('Set Configuration').first().json; const item = $json; const body = { source_relative_path: item.relative_path, markdown_content: item.markdown_content, source_content_sha256: item.content_sha256, tone: config.tone, audience: config.audience, variant: config.variant }; const url = (item.source_public_url || '').trim(); const theme = (config.topic_theme || '').trim(); if (url) body.source_public_url = url; if (theme) body.topic_theme = theme; return JSON.stringify(body); })() }}",
        "options": {}
      },
