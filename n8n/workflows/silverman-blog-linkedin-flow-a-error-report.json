    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Build secret-safe orchestration-failure report body (US-030).\nconst cfg = $('Set Configuration').first().json;\nconst src = $input.first().json || {};\nconst execution = src.execution || {};\nconst workflow = src.workflow || {};\n\nfunction safeToken(value, fallback) {\n  const raw = String(value == null ? '' : value).trim().replace(/\\s+/g, '-');\n  const cleaned = raw.replace(/[^A-Za-z0-9._:-]/g, '');\n  if (!cleaned || !/^[A-Za-z0-9][A-Za-z0-9._:-]{0,199}$/.test(cleaned)) {\n    return fallback;\n  }\n  return cleaned.slice(0, 200);\n}\n\nconst workflowId = safeToken(workflow.id, 'silvermanFlowAPublish01');\nconst executionId = safeToken(execution.id, null);\nconst nodeName = safeToken(execution.lastNodeExecuted, null);\n\nconst body = {\n  workflow_id: workflowId,\n  reason_code: 'n8n_error_trigger',\n};\nif (executionId) body.execution_id = executionId;\nif (nodeName) body.node_name = nodeName;\n\nreturn [{\n  json: {\n    worker_base_url: cfg.worker_base_url,\n    worker_api_key: cfg.worker_api_key,\n    report_body: body,\n  },\n}];\n"
      },
      "id": "b2000002-0002-4002-8002-000000000003",
      "name": "Build Safe Report Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.worker_base_url }}/flow-a/operational-alerts/report-orchestration-failure",
