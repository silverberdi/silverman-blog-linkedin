        "jsCode": "// Best-effort release of Flow A single-flight lock (US-010).\nconst fs = require('fs');\nconst LOCK_PATH = '/home/node/.n8n-files/.silverman-flow-a-single-flight.lock';\nconst staticData = $getWorkflowStaticData('global');\nconst executionId = String($execution.id);\nconst lock = staticData.flowASingleFlight || null;\nif (lock && String(lock.execution_id) === executionId) {\n  delete staticData.flowASingleFlight;\n}\ntry {\n  if (fs.existsSync(LOCK_PATH)) {\n    const cur = JSON.parse(fs.readFileSync(LOCK_PATH, 'utf8'));\n    if (!cur || String(cur.execution_id) === executionId) {\n      fs.unlinkSync(LOCK_PATH);\n    }\n  }\n} catch (e) {\n  // best effort\n}\nconst incoming = $input.first().json;\nreturn [{ json: { ...incoming, single_flight_released: true } }];\n"
