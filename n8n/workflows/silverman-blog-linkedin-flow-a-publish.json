      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Single-flight guard (US-010). TTL 2h.\n// Primary: workflow static data. Fallback: lockfile on shared n8n files mount\n// (so CLI/sidecar executes can also observe locks).\nconst TTL_MS = 2 * 60 * 60 * 1000;\nconst LOCK_PATH = '/home/node/.n8n-files/.silverman-flow-a-single-flight.lock';\nconst fs = require('fs');\nconst staticData = $getWorkflowStaticData('global');\nconst now = Date.now();\nconst nowIso = new Date(now).toISOString();\nconst executionId = String($execution.id);\nconst incoming = $input.first().json;\n\nfunction readFileLock() {\n  try {\n    if (!fs.existsSync(LOCK_PATH)) return null;\n    return JSON.parse(fs.readFileSync(LOCK_PATH, 'utf8'));\n  } catch (e) {\n    return null;\n  }\n}\n\nfunction writeFileLock(lock) {\n  fs.writeFileSync(LOCK_PATH, JSON.stringify(lock), 'utf8');\n}\n\nfunction lockHeld(lock) {\n  const acquiredAt = lock && typeof lock.acquired_at_ms === 'number' ? lock.acquired_at_ms : null;\n  return Boolean(lock && acquiredAt !== null && (now - acquiredAt) < TTL_MS);\n}\n\nlet lock = staticData.flowASingleFlight || null;\nif (!lockHeld(lock)) {\n  const fileLock = readFileLock();\n  if (lockHeld(fileLock)) {\n    lock = fileLock;\n  }\n}\n\nif (lockHeld(lock)) {\n  return [{\n    json: {\n      ...incoming,\n      single_flight_acquired: false,\n      outcome: 'skipped_already_running',\n      single_flight_lock_execution_id: lock.execution_id || null,\n      single_flight_lock_acquired_at_utc: lock.acquired_at_utc || null,\n      single_flight_ttl_hours: 2,\n      checked_at_utc: nowIso,\n    }\n  }];\n}\n\nconst acquired = {\n  execution_id: executionId,\n  acquired_at_ms: now,\n  acquired_at_utc: nowIso,\n};\nstaticData.flowASingleFlight = acquired;\ntry {\n  writeFileLock(acquired);\n} catch (e) {\n  // If shared mount unavailable, static-data lock still applies for in-process runs.\n}\n\nreturn [{\n  json: {\n    ...incoming,\n    single_flight_acquired: true,\n    outcome: 'lock_acquired',\n    single_flight_lock_execution_id: executionId,\n    single_flight_lock_acquired_at_utc: nowIso,\n    single_flight_ttl_hours: 2,\n    checked_at_utc: nowIso,\n  }\n}];\n"
      },
      "id": "1fb01096-5df1-4336-b8ca-18cbad8bf3a9",
      "name": "Single-Flight Guard",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        300
      ],
      "notes": "US-010 single-flight: static-data + shared-mount lockfile fallback, TTL 2h. If lock held \u2192 outcome skipped_already_running. Worker idempotency remains the completed-work safety net."
    },
