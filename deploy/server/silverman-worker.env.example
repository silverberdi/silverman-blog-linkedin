# Server-local environment for silverman-blog-linkedin-worker.
#
# Copy this file to .env in the deployment directory on the Ubuntu server:
#   cp silverman-worker.env.example .env
#
# Edit .env with real secret values on the server only.
# NEVER commit .env or real API keys to git.

# Required: Bearer token for authenticated worker endpoints.
# Must match worker_api_key in the n8n workflow Set Configuration node.
SILVERMAN_BLOG_LINKEDIN_API_KEY=CHANGE_ME_WORKER_API_KEY

# Required for POST /generate-linkedin-draft (optional for health and process-ready smoke).
DEEPSEEK_API_KEY=CHANGE_ME_DEEPSEEK_API_KEY

# Optional DeepSeek tuning (defaults shown).
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_OUTPUT_TOKENS=1024

# Flow A blog publish: host path to the GitHub Pages repo checkout (silverberdi.github.io).
# Mounted into the worker container as /public-blog via silverman-worker.compose.yaml.
# The checkout MUST contain _posts/ and assets/images/ before Flow A publish smoke.
# The deploy script does not clone this repo automatically.
SILVERMAN_PUBLIC_BLOG_REPO_PATH=/home/silverman/silverberdi.github.io

# Canonical public site URL for published blog posts (default https://silverman.pro).
SILVERMAN_SITE_URL=https://silverman.pro

# ComfyUI blog image generation (optional — disabled by default).
# When enabled, Flow A publish generates missing companion PNG + image front matter before validation.
# ComfyUI may be local/LAN or hosted (e.g. Comfy Cloud https://cloud.comfy.org).
# Hosted deployments may need SILVERMAN_COMFYUI_API_PREFIX=/api and an API key.
# Partner Node workflows may require SILVERMAN_COMFYUI_EXTRA_DATA_API_KEY_FIELD.
# Verify exact endpoint shape with your operator documentation.
# SILVERMAN_COMFYUI_IMAGE_ENABLED=false
# SILVERMAN_COMFYUI_BASE_URL=http://127.0.0.1:8188
# SILVERMAN_COMFYUI_BASE_URL=https://cloud.comfy.org
# SILVERMAN_COMFYUI_API_PREFIX=/api
# SILVERMAN_COMFYUI_API_KEY=CHANGE_ME_COMFYUI_API_KEY
# Comfy Cloud: X-API-Key header (raw key, not Bearer). Local/hosted Bearer APIs: Authorization.
# SILVERMAN_COMFYUI_AUTH_HEADER_NAME=X-API-Key
# Partner Nodes / OpenAI workflow: include Comfy account key in /prompt extra_data.
# SILVERMAN_COMFYUI_EXTRA_DATA_API_KEY_FIELD=api_key_comfy_org
# Default Comfy Cloud workflow: prompts/comfyui/silverman-blog-openai-gpt-image.json (1536x1024 preset).
# Local Stable Diffusion workflow: prompts/comfyui/blog-image-workflow.json (1200x900 bindings).
# SILVERMAN_COMFYUI_WORKFLOW_PATH=/path/to/silverman-blog-openai-gpt-image.json
# SILVERMAN_COMFYUI_TIMEOUT_SECONDS=120
# SILVERMAN_COMFYUI_IMAGE_WIDTH=1200
# SILVERMAN_COMFYUI_IMAGE_HEIGHT=900
# SILVERMAN_COMFYUI_DRY_RUN=false

# LinkedIn OAuth (primary production credential path).
# Requires LinkedIn Developer App products: Share on LinkedIn + Sign In with LinkedIn (OpenID Connect).
# Scopes: openid profile w_member_social
# Redirect URL registered in LinkedIn app: https://api.silverman.pro/linkedin/oauth/callback
SILVERMAN_LINKEDIN_CLIENT_ID=CHANGE_ME_LINKEDIN_CLIENT_ID
SILVERMAN_LINKEDIN_CLIENT_SECRET=CHANGE_ME_LINKEDIN_CLIENT_SECRET
SILVERMAN_LINKEDIN_REDIRECT_URI=https://api.silverman.pro/linkedin/oauth/callback
# Token store outside editorial workspace mount; dedicated secrets volume (see deployment docs).
# Host: /home/silverman/silverman-blog-linkedin-worker/secrets (chmod 700)
# Container: /secrets/linkedin-oauth-tokens.json (chmod 600 on file after first write)
SILVERMAN_LINKEDIN_TOKEN_STORE_PATH=/secrets/linkedin-oauth/linkedin-oauth-tokens.json
# Optional OAuth tuning (defaults shown).
# SILVERMAN_LINKEDIN_OAUTH_STATE_TTL_SECONDS=600
# SILVERMAN_LINKEDIN_TOKEN_REFRESH_SKEW_SECONDS=300

# LinkedIn publication (optional — required only for real POST /publish-linkedin-due-variants).
# Queue and cancel endpoints do not call LinkedIn API. Real publish requires publication enabled.
# Manual env token fallback only when token store is empty/unconfigured (Postman / emergency).
# Not used after refresh failure or reauthorization-required states.
# SILVERMAN_LINKEDIN_ACCESS_TOKEN=CHANGE_ME_LINKEDIN_ACCESS_TOKEN
# SILVERMAN_LINKEDIN_MEMBER_URN=urn:li:person:CHANGE_ME
# Must be true for real LinkedIn API calls (dry_run=false on publish-due).
SILVERMAN_LINKEDIN_PUBLICATION_ENABLED=false
# Safety delay before a queued variant is eligible for publish (default 120 minutes).
SILVERMAN_LINKEDIN_DEFAULT_SAFETY_DELAY_MINUTES=120
# Optional LinkedIn REST API version header (YYYYMM). Default 202606.
# SILVERMAN_LINKEDIN_API_VERSION=202606

# Git publication (optional — disabled by default; requires deploy key mounts in compose).
# Commit/push runs only when SILVERMAN_BLOG_GIT_PUBLICATION_ENABLED=true AND the HTTP request includes git_publication: true.
# SILVERMAN_BLOG_GIT_PUBLICATION_ENABLED=false
# SILVERMAN_BLOG_GIT_PUBLICATION_BRANCH=main
# SILVERMAN_BLOG_GIT_PUBLICATION_REMOTE=origin
# SILVERMAN_BLOG_GIT_COMMIT_MESSAGE_TEMPLATE=Publish {public_slug} ({campaign_id}) {publication_date}
# Container-side Git SSH for subprocess git push (paths match silverman-worker.compose.yaml mounts):
GIT_SSH_COMMAND=ssh -i /secrets/github-pages-deploy-key -o IdentitiesOnly=yes -o UserKnownHostsFile=/secrets/known_hosts -o StrictHostKeyChecking=yes
