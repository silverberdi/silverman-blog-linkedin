# UAT pairing overlay (US-094 / BL-034 Story 2)
# Copy matching keys into the stack .env for a UAT deploy profile.
# Placeholders only — NEVER commit real API keys or bearer tokens.
# Overlays document intended pairing; they do NOT claim a live second UAT
# host or full BL-029 CI/UAT stand-up is complete.
#
# ADR-0001: n8n continues to call the worker HTTP API only — never the UI.

# Worker stack identity (advertised on GET /health as deployment_environment)
SILVERMAN_DEPLOYMENT_ENVIRONMENT=uat

# Separated UI → UAT worker API (distinct from prod placeholder)
SILVERMAN_OPERATOR_UI_API_BASE_URL=http://uat-worker.example.local:8010
SILVERMAN_OPERATOR_UI_ENV_LABEL=uat
SILVERMAN_OPERATOR_UI_HOST_PORT=8011

# Worker CORS allowlist for the UAT UI origin (no wildcard)
SILVERMAN_OPERATOR_UI_ORIGINS=http://uat-ui.example.local:8011
