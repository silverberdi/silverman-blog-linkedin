# US-099 front-only public UI overlay (placeholders only — NEVER commit secrets).
#
# Activates Cloudflare Tunnel (or equivalent) publishing of the separated operator UI
# only. Worker API stays LAN / private-network. Browser uses same-origin private hop
# (SILVERMAN_OPERATOR_UI_API_BASE_URL=/); nginx in the UI container proxies typed-client
# routes and /auth/* to the private worker over Docker DNS.
#
# Distinct from the LinkedIn OAuth public callback exception (api.silverman.pro) —
# do not publish the Authority Manager worker API as a general public hostname.
#
# ADR-0001: n8n continues to call the private worker HTTP API only — never the UI.
# Cookie SameSite=Lax + Secure on HTTPS remains correct for same-origin hop
# (no JWT iss/aud/exp/allowlist changes).

# --- Separated UI (public origin via tunnel; private hop to worker) ---
SILVERMAN_OPERATOR_UI_API_BASE_URL=/
SILVERMAN_OPERATOR_UI_WORKER_UPSTREAM=silverman-blog-linkedin-worker:8000
SILVERMAN_OPERATOR_UI_ENV_LABEL=prod
SILVERMAN_OPERATOR_UI_HOST_PORT=8011
SILVERMAN_OPERATOR_GOOGLE_AUTH_ENABLED=true

# Worker stack identity (must match UI env label)
SILVERMAN_DEPLOYMENT_ENVIRONMENT=prod

# Residual cross-origin CORS allowlist (exact public UI origin). Prefer same-origin
# hop so console API calls need no CORS; still allowlist the public origin when any
# cross-origin remains. NEVER use wildcard '*'.
# Replace with the real Cloudflare UI hostname when activating live topology.
SILVERMAN_OPERATOR_UI_ORIGINS=https://authority.example.silverman.pro

# Google OAuth redirect/callback MUST use the public UI origin (proxied /auth/*).
# Register the same redirect URI in the Google Cloud OAuth client.
SILVERMAN_OPERATOR_GOOGLE_REDIRECT_URI=https://authority.example.silverman.pro/auth/google/callback
SILVERMAN_OPERATOR_UI_SUCCESS_REDIRECT=https://authority.example.silverman.pro/

# Secrets (set on server .env only — placeholders here):
# SILVERMAN_OPERATOR_GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_OAUTH_CLIENT_ID
# SILVERMAN_OPERATOR_GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_OAUTH_CLIENT_SECRET
# SILVERMAN_OPERATOR_SESSION_SECRET=CHANGE_ME_OPERATOR_SESSION_SECRET
#
# Cloudflare Tunnel connector token stays in cloudflared credentials / host secret
# store — NEVER paste into this file, git, docs, or UI config.js.
