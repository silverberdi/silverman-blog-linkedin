# Prod pairing overlay (US-094 / BL-034 Story 2)
# Copy matching keys into the stack .env for a prod deploy profile.
# Placeholders only — NEVER commit real API keys or bearer tokens.
#
# Recommended for the current single LAN authority stack at 192.168.0.194
# until a second UAT stack exists (BL-029). Labels are stack identity, not
# a claim of public internet exposure.
#
# ADR-0001: n8n continues to call the worker HTTP API only — never the UI.

# Worker stack identity (advertised on GET /health as deployment_environment)
SILVERMAN_DEPLOYMENT_ENVIRONMENT=prod

# Separated UI → prod worker API (distinct from UAT placeholder)
SILVERMAN_OPERATOR_UI_API_BASE_URL=http://192.168.0.194:8010
SILVERMAN_OPERATOR_UI_ENV_LABEL=prod
SILVERMAN_OPERATOR_UI_HOST_PORT=8011

# Worker CORS allowlist for the prod UI origin (no wildcard)
SILVERMAN_OPERATOR_UI_ORIGINS=http://192.168.0.194:8011
