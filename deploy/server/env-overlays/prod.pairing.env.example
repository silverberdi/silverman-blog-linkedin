# Prod pairing overlay (US-094 / BL-034 Story 2; US-099 private-hop compatible)
# Copy matching keys into the stack .env for a prod deploy profile.
# Placeholders only — NEVER commit real API keys or bearer tokens.
#
# Recommended for the current single LAN authority stack at 192.168.0.194
# until a second UAT stack exists (BL-029). Labels are stack identity, not
# a claim of public internet exposure by themselves.
#
# For Cloudflare front-only public UI, also see front-only.public-ui.env.example.
#
# ADR-0001: n8n continues to call the worker HTTP API only — never the UI.

# Worker stack identity (advertised on GET /health as deployment_environment)
SILVERMAN_DEPLOYMENT_ENVIRONMENT=prod

# Separated UI → private hop (preferred) or absolute LAN worker origin
SILVERMAN_OPERATOR_UI_API_BASE_URL=/
SILVERMAN_OPERATOR_UI_WORKER_UPSTREAM=silverman-blog-linkedin-worker:8000
SILVERMAN_OPERATOR_UI_ENV_LABEL=prod
SILVERMAN_OPERATOR_UI_HOST_PORT=8011

# Worker CORS allowlist for residual cross-origin (exact origins only; no wildcard).
# Same-origin private hop does not require CORS for console API calls; keep LAN
# UI origin listed when any absolute-base dual path remains.
SILVERMAN_OPERATOR_UI_ORIGINS=http://192.168.0.194:8011
