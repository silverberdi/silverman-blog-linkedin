# Optional env example for the separated operator UI container (US-093 / US-094).
# Copy values into the server .env used by compose (or a UI-specific env file).
# NEVER commit real API keys or bearer tokens.
#
# See also deploy/server/env-overlays/{uat,prod}.pairing.env.example for
# matching worker + UI defaults per environment.

# Absolute worker API origin (no trailing route path). Placeholder only.
SILVERMAN_OPERATOR_UI_API_BASE_URL=http://192.168.0.194:8010

# Required in separated-UI mode (US-094): uat | prod (case-insensitive).
# Must match worker SILVERMAN_DEPLOYMENT_ENVIRONMENT / health deployment_environment.
SILVERMAN_OPERATOR_UI_ENV_LABEL=prod

# Host port published for the UI (default 8011). Distinct from worker 8010.
SILVERMAN_OPERATOR_UI_HOST_PORT=8011
