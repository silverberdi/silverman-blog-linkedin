# Optional env example for the separated operator UI container
# (US-093 / US-094 / US-097 / US-099).
# Copy values into the server .env used by compose (or a UI-specific env file).
# NEVER commit real API keys, bearer tokens, OAuth client secrets, or tunnel tokens.
#
# See also:
# - deploy/server/env-overlays/{uat,prod}.pairing.env.example
# - deploy/server/env-overlays/front-only.public-ui.env.example (US-099)

# Same-origin private hop (US-099 preferred): browser calls relative paths on the UI
# origin; nginx proxies typed-client + /auth/* to the private worker.
# Absolute worker origin remains valid for intentional cross-origin LAN use.
SILVERMAN_OPERATOR_UI_API_BASE_URL=/

# Private worker upstream for the UI container nginx hop (host:port, Docker DNS).
# Do NOT set this to a public internet Authority Manager API hostname.
SILVERMAN_OPERATOR_UI_WORKER_UPSTREAM=silverman-blog-linkedin-worker:8000

# Required in separated-UI mode (US-094): uat | prod (case-insensitive).
# Must match worker SILVERMAN_DEPLOYMENT_ENVIRONMENT / health deployment_environment.
SILVERMAN_OPERATOR_UI_ENV_LABEL=prod

# Host port published for the UI (default 8011). Distinct from worker 8010.
SILVERMAN_OPERATOR_UI_HOST_PORT=8011

# US-097: non-secret flag injected into UI config.js. When true, Sign in uses Google OIDC
# (no worker API-key paste). Google client secret / session signing stay on the worker only.
SILVERMAN_OPERATOR_GOOGLE_AUTH_ENABLED=false
