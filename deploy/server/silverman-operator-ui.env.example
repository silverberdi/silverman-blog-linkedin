# Optional env example for the separated operator UI container (US-093).
# Copy values into the server .env used by compose (or a UI-specific env file).
# NEVER commit real API keys or bearer tokens.

# Absolute worker API origin (no trailing route path). Placeholder only.
SILVERMAN_OPERATOR_UI_API_BASE_URL=http://192.168.0.194:8010

# Reserved for US-094 environment pairing display — unused for enforcement in US-093.
# SILVERMAN_OPERATOR_UI_ENV_LABEL=lan

# Host port published for the UI (default 8011). Distinct from worker 8010.
SILVERMAN_OPERATOR_UI_HOST_PORT=8011
